{
  "name": "android-devkit",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:packages": "pnpm -r --filter './packages/*' run build",
    "build:apps": "pnpm -r --filter './apps/*' run build",
    "package": "pnpm -r --filter './apps/*' run package",
    "dev": "pnpm --filter 'android-devkit' run dev",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm exec oxlint",
    "clean": "pnpm -r run clean"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@types/node": "catalog:",
    "oxlint": "^1.51.0",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
}
