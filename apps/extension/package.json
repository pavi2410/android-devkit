{
  "name": "android-devkit",
  "displayName": "Android DevKit",
  "description": "Comprehensive Android development tools for VS Code",
  "version": "0.4.0",
  "publisher": "pavi2410",
  "license": "MIT",
  "icon": "icon-128.png",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/pavi2410/android-devkit"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "extensionDependencies": [
    "vscjava.vscode-gradle"
  ],
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "android",
    "adb",
    "logcat",
    "gradle",
    "kotlin",
    "java",
    "emulator"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/build.gradle",
    "workspaceContains:**/build.gradle.kts",
    "workspaceContains:**/settings.gradle",
    "workspaceContains:**/settings.gradle.kts",
    "workspaceContains:**/AndroidManifest.xml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "androidDevkit-devices",
          "title": "Android Devices",
          "icon": "$(device-mobile)"
        },
        {
          "id": "androidDevkit-avd",
          "title": "Android Virtual Devices",
          "icon": "$(package)"
        },
        {
          "id": "androidDevkit-build",
          "title": "Android Build",
          "icon": "$(tools)"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "androidDevkit.projectLayout",
          "name": "Android",
          "icon": "$(device-mobile)",
          "contextualTitle": "Android Project"
        }
      ],
      "androidDevkit-devices": [
        {
          "id": "androidDevkit.devices",
          "name": "Devices",
          "icon": "$(device-mobile)",
          "contextualTitle": "Android Devices"
        },
        {
          "id": "androidDevkit.logcat",
          "name": "Logcat",
          "icon": "$(output)",
          "type": "tree",
          "contextualTitle": "Android Logcat",
          "visibility": "collapsed"
        },
        {
          "id": "androidDevkit.fileExplorer",
          "name": "Device Files",
          "icon": "$(folder)",
          "contextualTitle": "Device File Explorer",
          "visibility": "collapsed"
        }
      ],
      "androidDevkit-avd": [
        {
          "id": "androidDevkit.avdManager",
          "name": "Android Virtual Devices",
          "icon": "$(vm)",
          "contextualTitle": "Android Virtual Devices"
        }
      ],
      "androidDevkit-build": [
        {
          "id": "androidDevkit.buildRun",
          "name": "Build & Run",
          "icon": "$(play)",
          "contextualTitle": "Android Build & Run"
        },
        {
          "id": "androidDevkit.gradleTasks",
          "name": "Gradle Tasks",
          "icon": "$(list-tree)",
          "contextualTitle": "Gradle Tasks",
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "androidDevkit.refreshProjectLayout",
        "title": "Refresh Android Project",
        "icon": "$(refresh)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.refreshDevices",
        "title": "Refresh Devices",
        "icon": "$(refresh)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.takeScreenshot",
        "title": "Take Screenshot",
        "icon": "$(device-camera)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.rebootDevice",
        "title": "Reboot Device",
        "icon": "$(debug-restart)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.connectDevice",
        "title": "Connect Device (TCP/IP)",
        "icon": "$(plug)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.pairDevice",
        "title": "Pair Device (Wireless Debugging)",
        "icon": "$(radio-tower)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.enableTcpip",
        "title": "Enable TCP/IP Mode",
        "icon": "$(globe)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.openShell",
        "title": "Open ADB Shell",
        "icon": "$(terminal)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.testDeepLink",
        "title": "Test Deep Link",
        "icon": "$(link-external)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.recordScreen",
        "title": "Record Screen",
        "icon": "$(circle-filled)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.managePermissions",
        "title": "Manage App Permissions",
        "icon": "$(shield)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.browseFiles",
        "title": "Browse Device Files",
        "icon": "$(folder-opened)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.startLogcat",
        "title": "Start or Resume Logcat",
        "icon": "$(play)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.pauseLogcat",
        "title": "Pause Logcat",
        "icon": "$(debug-pause)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.stopLogcat",
        "title": "Stop Logcat",
        "icon": "$(debug-stop)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.clearLogcat",
        "title": "Clear Logcat",
        "icon": "$(clear-all)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.showLogcatOutput",
        "title": "Show Logcat Output",
        "icon": "$(output)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.logcatStatusMenu",
        "title": "Logcat Controls",
        "icon": "$(output)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.setLogcatFilter",
        "title": "Set Logcat Filter",
        "icon": "$(filter)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.setLogcatPackageFilter",
        "title": "Filter Logcat by Package",
        "icon": "$(package)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.refreshFileExplorer",
        "title": "Refresh File Explorer",
        "icon": "$(refresh)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.pullFile",
        "title": "Download from Device",
        "icon": "$(cloud-download)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.openDeviceFile",
        "title": "Open Device File",
        "icon": "$(go-to-file)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.pushFile",
        "title": "Upload to Device",
        "icon": "$(cloud-upload)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.deleteRemoteFile",
        "title": "Delete from Device",
        "icon": "$(trash)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.showSdkInfo",
        "title": "Show Android SDK Info",
        "icon": "$(info)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.refreshSdkPackages",
        "title": "Refresh SDK Packages",
        "icon": "$(refresh)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.installSdkPackage",
        "title": "Install SDK Package",
        "icon": "$(cloud-download)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.uninstallSdkPackage",
        "title": "Uninstall SDK Package",
        "icon": "$(trash)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.updateAllSdkPackages",
        "title": "Update All SDK Packages",
        "icon": "$(sync)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.refreshAvds",
        "title": "Refresh AVDs",
        "icon": "$(refresh)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.createAvd",
        "title": "Create Virtual Device",
        "icon": "$(add)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.launchAvd",
        "title": "Launch Emulator",
        "icon": "$(play)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.deleteAvd",
        "title": "Delete Virtual Device",
        "icon": "$(trash)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.wipeAvdData",
        "title": "Wipe AVD Data",
        "icon": "$(clear-all)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.refreshGradleTasks",
        "title": "Refresh Gradle Tasks",
        "icon": "$(refresh)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.syncGradle",
        "title": "Sync Gradle Project",
        "icon": "$(sync)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.runGradleTask",
        "title": "Run Gradle Task",
        "icon": "$(play)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.cleanBuild",
        "title": "Clean Build",
        "icon": "$(trash)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.assembleBuild",
        "title": "Assemble",
        "icon": "$(package)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.selectBuildVariant",
        "title": "Select Build Variant",
        "icon": "$(symbol-enum)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.selectRunTarget",
        "title": "Select Run Target Device",
        "icon": "$(device-mobile)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.buildVariant",
        "title": "Build",
        "icon": "$(package)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.runOnDevice",
        "title": "Run on Device",
        "icon": "$(play)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.stopApp",
        "title": "Stop App",
        "icon": "$(debug-stop)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.installApk",
        "title": "Install APK from File",
        "icon": "$(cloud-download)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.addToTerminalPath",
        "title": "Add Android SDK Tools to Terminal PATH",
        "icon": "$(terminal)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.commandMenu",
        "title": "Command Menu",
        "icon": "$(device-mobile)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.openSdkManager",
        "title": "Open SDK Manager",
        "icon": "$(package)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.uninstallApp",
        "title": "Uninstall App",
        "icon": "$(trash)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.clearAppData",
        "title": "Clear App Data",
        "icon": "$(clear-all)",
        "category": "Android DevKit"
      },
      {
        "command": "androidDevkit.exportLogcat",
        "title": "Export Logcat to File",
        "icon": "$(save)",
        "category": "Android DevKit"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "androidDevkit.refreshProjectLayout",
          "when": "view == androidDevkit.projectLayout",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.refreshDevices",
          "when": "view == androidDevkit.devices",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.connectDevice",
          "when": "view == androidDevkit.devices",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.pairDevice",
          "when": "view == androidDevkit.devices",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.startLogcat",
          "when": "view == androidDevkit.logcat && androidDevkit.hasDevices && !androidDevkit.logcatRunning",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.pauseLogcat",
          "when": "view == androidDevkit.logcat && androidDevkit.logcatRunning",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.stopLogcat",
          "when": "view == androidDevkit.logcat && androidDevkit.hasDevices && (androidDevkit.logcatRunning || androidDevkit.logcatPaused)",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.setLogcatFilter",
          "when": "view == androidDevkit.logcat && androidDevkit.hasDevices",
          "group": "1_filters"
        },
        {
          "command": "androidDevkit.setLogcatPackageFilter",
          "when": "view == androidDevkit.logcat && androidDevkit.hasDevices",
          "group": "1_filters"
        },
        {
          "command": "androidDevkit.showLogcatOutput",
          "when": "view == androidDevkit.logcat && androidDevkit.hasDevices",
          "group": "2_output"
        },
        {
          "command": "androidDevkit.clearLogcat",
          "when": "view == androidDevkit.logcat && androidDevkit.hasDevices",
          "group": "2_output"
        },
        {
          "command": "androidDevkit.exportLogcat",
          "when": "view == androidDevkit.logcat && androidDevkit.hasDevices",
          "group": "2_output"
        },
        {
          "command": "androidDevkit.refreshFileExplorer",
          "when": "view == androidDevkit.fileExplorer",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.refreshAvds",
          "when": "view == androidDevkit.avdManager",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.createAvd",
          "when": "view == androidDevkit.avdManager",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.openSdkManager",
          "when": "view == androidDevkit.avdManager",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.refreshGradleTasks",
          "when": "view == androidDevkit.gradleTasks",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.syncGradle",
          "when": "view == androidDevkit.gradleTasks",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.cleanBuild",
          "when": "view == androidDevkit.gradleTasks",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.runOnDevice",
          "when": "view == androidDevkit.buildRun",
          "group": "navigation"
        },
        {
          "command": "androidDevkit.stopApp",
          "when": "view == androidDevkit.buildRun",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "androidDevkit.takeScreenshot",
          "when": "view == androidDevkit.devices && viewItem == device",
          "group": "inline"
        },
        {
          "command": "androidDevkit.openShell",
          "when": "view == androidDevkit.devices && viewItem == device",
          "group": "inline"
        },
        {
          "command": "androidDevkit.browseFiles",
          "when": "view == androidDevkit.devices && viewItem == device",
          "group": "1_actions"
        },
        {
          "command": "androidDevkit.testDeepLink",
          "when": "view == androidDevkit.devices && viewItem == device",
          "group": "1_actions"
        },
        {
          "command": "androidDevkit.recordScreen",
          "when": "view == androidDevkit.devices && viewItem == device",
          "group": "1_actions"
        },
        {
          "command": "androidDevkit.managePermissions",
          "when": "view == androidDevkit.devices && viewItem == device",
          "group": "1_actions"
        },
        {
          "command": "androidDevkit.enableTcpip",
          "when": "view == androidDevkit.devices && viewItem == device",
          "group": "2_connection"
        },
        {
          "command": "androidDevkit.rebootDevice",
          "when": "view == androidDevkit.devices && viewItem == device",
          "group": "3_danger"
        },
        {
          "command": "androidDevkit.pullFile",
          "when": "view == androidDevkit.fileExplorer && viewItem == file",
          "group": "inline"
        },
        {
          "command": "androidDevkit.pushFile",
          "when": "view == androidDevkit.fileExplorer && viewItem == directory",
          "group": "inline"
        },
        {
          "command": "androidDevkit.deleteRemoteFile",
          "when": "view == androidDevkit.fileExplorer && viewItem =~ /file|directory/",
          "group": "9_danger"
        },
        {
          "command": "androidDevkit.launchAvd",
          "when": "view == androidDevkit.avdManager && viewItem == avd.stopped",
          "group": "inline"
        },
        {
          "command": "androidDevkit.deleteAvd",
          "when": "view == androidDevkit.avdManager && viewItem =~ /avd\\./",
          "group": "9_danger"
        },
        {
          "command": "androidDevkit.wipeAvdData",
          "when": "view == androidDevkit.avdManager && viewItem =~ /avd\\./",
          "group": "2_actions"
        },
        {
          "command": "androidDevkit.runGradleTask",
          "when": "view == androidDevkit.gradleTasks && viewItem == gradleTask",
          "group": "inline"
        },
        {
          "command": "androidDevkit.uninstallApp",
          "when": "view == androidDevkit.buildRun && viewItem == buildRunAction",
          "group": "9_danger"
        },
        {
          "command": "androidDevkit.clearAppData",
          "when": "view == androidDevkit.buildRun && viewItem == buildRunAction",
          "group": "9_danger"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "androidDevkit.devices",
        "contents": "No devices or emulators are connected.\n\n[Connect Device (TCP/IP)](command:androidDevkit.connectDevice)\n\n[Pair Device (Wireless Debugging)](command:androidDevkit.pairDevice)\n\n[Open Android Virtual Devices](command:androidDevkit.avdManager.focus)",
        "when": "!androidDevkit.hasDevices"
      },
      {
        "view": "androidDevkit.logcat",
        "contents": "Connect a device or start an emulator to use Logcat.\n\n[Open Android Virtual Devices](command:androidDevkit.avdManager.focus)\n\n[Connect Device (TCP/IP)](command:androidDevkit.connectDevice)",
        "when": "!androidDevkit.hasDevices"
      },
      {
        "view": "androidDevkit.logcat",
        "contents": "Start a Logcat session with safer defaults.\n\n[Start Logcat](command:androidDevkit.startLogcat)\n\n[Choose Package Filter](command:androidDevkit.setLogcatPackageFilter)\n\n[Show Output](command:androidDevkit.showLogcatOutput)",
        "when": "androidDevkit.hasDevices && !androidDevkit.logcatRunning && !androidDevkit.logcatPaused"
      },
      {
        "view": "androidDevkit.fileExplorer",
        "contents": "Select a device first, then open its files here.\n\n[Choose Device for File Explorer](command:androidDevkit.browseFiles)\n\n[Open Devices](command:androidDevkit.devices.focus)",
        "when": "!androidDevkit.fileExplorerHasDevice"
      },
      {
        "view": "androidDevkit.avdManager",
        "contents": "Android DevKit needs an SDK path before it can manage Android virtual devices.\n\n[Open SDK Setup](command:androidDevkit.showSdkInfo)\n\n[Open SDK Manager](command:androidDevkit.openSdkManager)",
        "when": "!androidDevkit.sdkConfigured"
      },
      {
        "view": "androidDevkit.avdManager",
        "contents": "No Android virtual devices are configured yet.\n\n[Create Virtual Device](command:androidDevkit.createAvd)\n\n[Open SDK Manager](command:androidDevkit.openSdkManager)",
        "when": "androidDevkit.sdkConfigured && !androidDevkit.hasAvds"
      }
    ],
    "configuration": {
      "title": "Android DevKit",
      "properties": {
        "androidDevkit.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Override the auto-detected Android SDK path. Leave empty to detect from environment variables or standard install locations."
        },
        "androidDevkit.logcat.defaultLogLevel": {
          "type": "string",
          "default": "I",
          "enum": ["V", "D", "I", "W", "E", "F"],
          "enumDescriptions": [
            "Verbose",
            "Debug",
            "Info",
            "Warning",
            "Error",
            "Fatal"
          ],
          "description": "Default minimum Logcat level for new sessions."
        },
        "androidDevkit.logcat.maxLines": {
          "type": "number",
          "default": 1e4,
          "description": "Maximum number of Logcat lines to keep in memory before older entries are discarded."
        }
      }
    },
    "configurationDefaults": {
      "[Log (ADK: Logcat)]": {
        "editor.wordWrap": "off"
      }
    },
    "walkthroughs": [
      {
        "id": "androidDevkit.getStarted",
        "title": "Get Started with Android DevKit",
        "description": "Set up your Android development environment in VS Code.",
        "steps": [
          {
            "id": "configureSdk",
            "title": "Configure Android SDK",
            "description": "Android DevKit needs to know where your Android SDK is installed.\n\nIt will auto-detect from `ANDROID_HOME`, or you can set it manually in settings.\n\n[Set SDK Path](command:androidDevkit.showSdkInfo)",
            "media": {
              "markdown": "media/walkthroughs/configureSdk.md"
            },
            "completionEvents": ["onSettingChanged:androidDevkit.sdkPath"]
          },
          {
            "id": "exploreDevices",
            "title": "Explore Connected Devices",
            "description": "View and manage your connected Android devices and emulators from the sidebar.\n\n[Open Device Manager](command:androidDevkit.devices.focus)",
            "media": {
              "markdown": "media/walkthroughs/exploreDevices.md"
            },
            "completionEvents": ["onView:androidDevkit.devices"]
          },
          {
            "id": "openSdkManager",
            "title": "Open SDK Manager",
            "description": "Install and manage Android SDK platforms, build tools, system images, and more — just like in Android Studio.\n\n[Open SDK Manager](command:androidDevkit.openSdkManager)",
            "media": {
              "markdown": "media/walkthroughs/openSdkManager.md"
            },
            "completionEvents": ["onCommand:androidDevkit.openSdkManager"]
          },
          {
            "id": "createAvd",
            "title": "Create a Virtual Device",
            "description": "Create, launch, and manage Android Virtual Devices (AVDs) for testing your apps.\n\n[Open Android Virtual Devices](command:androidDevkit.avdManager.focus)",
            "media": {
              "markdown": "media/walkthroughs/createAvd.md"
            },
            "completionEvents": ["onView:androidDevkit.avdManager"]
          },
          {
            "id": "viewLogcat",
            "title": "View Logcat",
            "description": "Stream real-time device logs to debug your apps.\n\n[Open Logcat](command:androidDevkit.logcat.focus)",
            "media": {
              "markdown": "media/walkthroughs/viewLogcat.md"
            },
            "completionEvents": ["onView:androidDevkit.logcat"]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run build",
    "build": "rolldown -c --minify",
    "dev": "rolldown -c --sourcemap --watch",
    "package": "mkdir -p build && bunx vsce package --no-dependencies -o build/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@android-devkit/android-sdk": "workspace:*",
    "@android-devkit/android-project": "workspace:*",
    "@android-devkit/adb": "workspace:*",
    "@android-devkit/sdkmanager": "workspace:*",
    "@android-devkit/avdmanager": "workspace:*",
    "@android-devkit/emulator": "workspace:*",
    "@android-devkit/logcat": "workspace:*",
    "@android-devkit/gradle": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "1.96.0",
    "@vscode/vsce": "^3.7.1",
    "rolldown": "^1.0.0-rc.9",
    "vscode-gradle": "^3.10.1"
  }
}
